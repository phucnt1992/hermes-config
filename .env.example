# Firecrawl configuration. If not set, Firecrawl will use default values.
FIRECRAWL_PORT=3002
FIRECRAWL_INTERNAL_PORT=3002
FIRECRAWL_HOST=0.0.0.0
FIRECRAWL_API_URL=http://host.docker.internal:3000
# OpenAI API configuration. If OPENAI_BASE_URL is not set, the OpenAI client will default to https://api.openai.com/v1
OPENAI_BASE_URL=https://example.com/v1
OPENAI_API_KEY=
# Postgres connection details for Firecrawl. If not set, Firecrawl will use SQLite instead.
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
# Align UID/GID across containers sharing the hermes-home volume. Defaults to the current user.
UID=$(id -u)
GID=$(id -g)

